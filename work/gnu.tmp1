set title 'program HELIOS - temperatures'
set xrange [9.000000000000000e+07:5.100000000000000e+08]
set yrange [2.682980106986601e+01:1.102259171393812e+02]
set xlabel 'Hz'
set ylabel '°Celsius'
set grid
set border
set pointsize 1
plot \
'ti1' with linespoints, \
'to1' with linespoints, \
'tm1' with linespoints, \
'tsdm1' with linespoints, \
'tmxm1' with linespoints
pause -1 '[ hit return to continue ]'

